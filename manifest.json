{
  "manifest_version": 3,
  "name": "PDF Explain",
  "version": "1.0.0",
  "description": "A fallback PDF viewer that rewrites complex pages into clearer content",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "templates/reader.html",
        "templates/reader.js",
        "styles/main.css",
        "lib/pdf.js",
        "lib/marked.min.js"
      ],
      "matches": ["*://*/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Explainer Mode"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
